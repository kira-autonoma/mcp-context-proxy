    "mcp-lazy-proxy": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kira-autonoma/mcp-context-proxy"
  },
  "homepage": "https://github.com/kira-autonoma/mcp-context-proxy#readme",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "proxy",
    "token-optimization",
